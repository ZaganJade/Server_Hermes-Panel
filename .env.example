APP_NAME="Hermes Panel"
APP_ENV=production
APP_DEBUG=false
APP_KEY=

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hermes_panel
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

CACHE_STORE=file
QUEUE_CONNECTION=database

# Panel Configuration
PANEL_NAME="Hermes Panel"
PANEL_USERNAME=admin
PANEL_PASSWORD=changeme
PANEL_OWNER_NUMBERS=
PANEL_SESSION_LIFETIME=120
PANEL_PROJECTS_DIR=Project
PANEL_MAX_UPLOAD_SIZE=10485760
PANEL_BYPASS_PASSWORD=

# Reverb (WebSocket for Terminal)
REVERB_HOST=0.0.0.0
REVERB_PORT=8081
REVERB_SCHEME=http
